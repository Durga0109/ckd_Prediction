# Environment variables for CKD Clinical System

# Application
APP_NAME=CKD Clinical System
APP_VERSION=1.0.0

# Database
DATABASE_URL=sqlite:///./ckd_clinical.db

# Security (CHANGE THIS IN PRODUCTION!)
SECRET_KEY=your-super-secret-key-change-this-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ML Models Path
ML_MODELS_PATH=../
